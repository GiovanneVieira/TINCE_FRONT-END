{
  "name": "TINCE Expo Watch",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "tince-front",
  "workspaceFolder": "/app",
  "customizations": {
    "vscode": {
      "extensions": [
        "expo.vscode-expo-tools",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "dsznajder.es7-react-js-snippets"
      ]
    }
  },
  "remoteUser": "root", // Alterado para root
  "forwardPorts": [8081]
}